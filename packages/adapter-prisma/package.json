{
  "name": "@odysseon/whoami-adapter-prisma",
  "version": "0.0.0",
  "description": "Prisma adapter for whoami authentication library",
  "keywords": [
    "adapter",
    "auth",
    "prisma",
    "whoami"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/odysseon/whoami.git",
    "directory": "packages/adapter-prisma"
  },
  "files": [
    "dist",
    "schema.prisma",
    "scripts"
  ],
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && tsc -p tsconfig.types.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@odysseon/whoami-core": "workspace:*"
  },
  "peerDependencies": {
    "@odysseon/whoami-core": ">=12.0.0-dev.0"
  },
  "packageManager": "pnpm@10.33.2"
}
