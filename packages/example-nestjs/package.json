{
  "name": "@odysseon/whoami-example-nestjs",
  "version": "9.9.14-dev.0",
  "private": true,
  "description": "NestJS example app demonstrating all @odysseon/whoami-* adapters",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\"",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "postinstall": "node ../adapter-prisma/scripts/merge-schema.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.6",
    "@odysseon/whoami-adapter-argon2": "workspace:*",
    "@odysseon/whoami-adapter-jose": "workspace:*",
    "@odysseon/whoami-adapter-nestjs": "workspace:*",
    "@odysseon/whoami-adapter-prisma": "workspace:*",
    "@odysseon/whoami-adapter-webcrypto": "workspace:*",
    "@odysseon/whoami-core": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "prisma": "^7.8.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
