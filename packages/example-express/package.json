{
  "name": "@odysseon/whoami-example-express",
  "version": "9.9.14-dev.0",
  "private": true,
  "description": "Simple Express app that consumes @odysseon/whoami-core",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "postinstall": "node ../adapter-prisma/scripts/merge-schema.js",
    "prebuild": "prisma generate",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\"",
    "start": "node dist/index.js",
    "dev": "tsx --tsconfig tsconfig.dev.json src/index.ts",
    "test": "node --import tsx --test src/**/*.spec.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@odysseon/whoami-adapter-argon2": "workspace:*",
    "@odysseon/whoami-adapter-jose": "workspace:*",
    "@odysseon/whoami-adapter-prisma": "workspace:*",
    "@odysseon/whoami-adapter-webcrypto": "workspace:*",
    "@odysseon/whoami-core": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^7.8.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
