{
  "name": "@odysseon/whoami-core",
  "version": "11.2.0",
  "description": "Framework-agnostic identity and authentication core",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./password": {
      "import": "./dist/esm/modules/password/index.js",
      "require": "./dist/cjs/modules/password/index.js",
      "types": "./dist/types/modules/password/index.d.ts"
    },
    "./oauth": {
      "import": "./dist/esm/modules/oauth/index.js",
      "require": "./dist/cjs/modules/oauth/index.js",
      "types": "./dist/types/modules/oauth/index.d.ts"
    },
    "./magiclink": {
      "import": "./dist/esm/modules/magiclink/index.js",
      "require": "./dist/cjs/modules/magiclink/index.js",
      "types": "./dist/types/modules/magiclink/index.d.ts"
    },
    "./kernel": {
      "import": "./dist/esm/kernel/index.js",
      "require": "./dist/cjs/kernel/index.js",
      "types": "./dist/types/kernel/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run clean && pnpm run build:esm && pnpm run build:cjs && pnpm run build:types",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "clean": "rm -rf dist",
    "test": "node --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "verify": "bash scripts/verify.sh"
  },
  "keywords": [
    "authentication",
    "auth",
    "password",
    "oauth",
    "magic-link",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "typescript": "^6.0.3"
  }
}
