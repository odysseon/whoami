{
  "name": "@odysseon/whoami-core",
  "version": "12.0.0",
  "description": "Framework-agnostic identity and authentication core",
  "keywords": [
    "auth",
    "authentication",
    "magic-link",
    "oauth",
    "password",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/odysseon/whoami.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./password": {
      "import": "./dist/modules/password/index.js",
      "types": "./dist/modules/password/index.d.ts"
    },
    "./oauth": {
      "import": "./dist/modules/oauth/index.js",
      "types": "./dist/modules/oauth/index.d.ts"
    },
    "./magiclink": {
      "import": "./dist/modules/magiclink/index.js",
      "types": "./dist/modules/magiclink/index.d.ts"
    },
    "./kernel": {
      "import": "./dist/kernel/index.js",
      "types": "./dist/kernel/index.d.ts"
    },
    "./internal": {
      "import": "./dist/internal/index.js",
      "types": "./dist/internal/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "pnpm run clean && pnpm run build:esm",
    "build:esm": "tsc",
    "clean": "rm -rf dist",
    "test": "node --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "verify": "bash scripts/verify.sh"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
