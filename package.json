{
  "name": "whoami",
  "private": true,
  "keywords": [],
  "license": "ISC",
  "author": "",
  "scripts": {
    "prepare": "husky",
    "build": "pnpm -r build",
    "test": "node --import ./scripts/register-tsx.mjs --test packages/**/*.spec.ts",
    "test:cov": "node --import ./scripts/register-tsx.mjs --experimental-test-coverage --test-coverage-exclude=\"**/dist/**\" --test packages/**/*.spec.ts",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"packages/**/*.ts\"",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --no-frozen-lockfile",
    "release": "pnpm build && changeset publish",
    "pre:enter": "changeset pre enter",
    "pre:exit": "changeset pre exit",
    "release:dev": "changeset version --snapshot dev && pnpm build && changeset publish --tag dev --no-git-tag"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@swc/core": "^1.15.21",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  }
}
